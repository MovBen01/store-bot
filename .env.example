BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_IDS=123456789,987654321

# Price provider: "mock" or "userbot"
PRICE_PROVIDER=mock

# Markup mode: "percent" or "fixed"
MARKUP_MODE=percent
# Default markup value (e.g. 10 = 10% or 10 = 10 rub fixed)
MARKUP_VALUE=10

# SQLite DB path
DB_PATH=shop.db

# Userbot credentials (only if PRICE_PROVIDER=userbot)
# USERBOT_API_ID=
# USERBOT_API_HASH=
# USERBOT_SESSION=userbot_session
# BIGSALE_BOT_USERNAME=BigSaleApple

# WebApp URL (Railway URL после деплоя)
WEBAPP_URL=https://your-project.up.railway.app
